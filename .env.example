# The Odds API – https://the-odds-api.com
ODDS_API_KEY=

# Monthly request budget (paid tier). Shared with match-bet.
ODDS_API_MONTHLY_BUDGET=20000
# This project's share of the budget (the rest is for match-bet).
ODDS_API_PROJECT_SHARE=10000
# Identifier used in the quota_usage table.
ODDS_API_PROJECT_TAG=bet-advisor

# Betfair Exchange (AU) – https://docs.developer.betfair.com
#
# Delayed app key: free (requires a verified Betfair AU account).
# Has 1-180 second price delay and CANNOT place bets.
# Used for reading closing prices in Phase 5.5.
# Sign up at https://developer.betfair.com -- select "Delayed" key type.
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_APP_KEY_DELAYED=
BETFAIR_CERT_PATH=
BETFAIR_CERT_KEY_PATH=
#
# BETFAIR_APP_KEY (live key) -- costs ~AUD 1000 one-off fee.
# Deferred until model proves positive CLV over a full AFL season.
# Required for Phase 9 (live Betfair execution streaming).
# BETFAIR_APP_KEY=

# Paper-trading bankroll (notional $AUD)
BANKROLL=1000

# Storage paths
DUCKDB_PATH=./data/bet_advisor.duckdb
SQLITE_PATH=./data/bet_advisor.sqlite
PARQUET_DIR=./data/parquet

# Optional: news/injury LLM parser (Phase 8)
ANTHROPIC_API_KEY=
